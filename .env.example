# VITE_SOUNDCLOUD_CLIENT_ID: Required for SoundCloud OAuth and API verification.
# You must create an app in the SoundCloud developer portal to get this ID.
VITE_SOUNDCLOUD_CLIENT_ID=
SOUNDCLOUD_CLIENT_SECRET=""

# VITE_APP_URL: The URL where this applet is hosted (used for OAuth Redirect).
VITE_APP_URL="http://localhost:3000"

# VITE_DRIVE_DOWNLOAD_URL: The Google Drive link to the WAV file.
VITE_DRIVE_DOWNLOAD_URL="https://drive.google.com/file/d/your_file_id/view"

# Track Configuration
VITE_SOUNDCLOUD_TRACK_ID="123456789"
VITE_SOUNDCLOUD_TRACK_URL="https://soundcloud.com/caiosantosdj/tomajogadinha"
VITE_TRACK_TITLE="Toma Jogadinha"
VITE_TRACK_ARTIST="Caiosantos dj, alexia"
VITE_TRACK_ARTWORK_URL="https://images.unsplash.com/photo-1614613535308-eb5fbd3d2c17?q=80&w=500&auto=format&fit=crop"
